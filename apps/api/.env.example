# ──────────────────────────────────────────────
#  Lotto Journal — API Environment Variables
#  Copy this file to .env and fill in the values
#  $ cp .env.example .env
# ──────────────────────────────────────────────

# ── Database ───────────────────────────────────
# PostgreSQL connection string (DSN).
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>?sslmode=<mode>
DB_DSN="postgresql://lotto:password@localhost:5432/lotto_db?sslmode=disable"

# ── Server ─────────────────────────────────────
# TCP port the Fiber HTTP server listens on.
PORT=":3000"

# ── LINE Messaging API ─────────────────────────
# Used to verify that incoming webhook requests genuinely originate from LINE.
LINE_CHANNEL_SECRET="your_line_channel_secret_here"
# Long-lived token used to call LINE's reply / push message APIs.
LINE_CHANNEL_ACCESS_TOKEN="your_line_channel_access_token_here"
