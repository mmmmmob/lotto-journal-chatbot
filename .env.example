# ──────────────────────────────────────────────────────────────────────────
# Environment configuration for the Lotto Journal monorepo.
# Copy this file to `.env.local` and fill in your values.
# $ cp .env.example .env
# Do NOT use quotes around values — this file is read by both shell and Make.
# ──────────────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────────────────
# Used by docker-compose to create the PostgreSQL container.

DB_USERNAME=postgres
DB_PASSWORD=yourpassword
DB_NAME=lotto_journal

# ── App ────────────────────────────────────────────────────────────────────────
# Used by the Go API (apps/api). DB_DSN must match the DB_* values above.

DB_DSN=postgres://postgres:yourpassword@localhost:5432/lotto_journal?sslmode=disable
PORT=:3000
