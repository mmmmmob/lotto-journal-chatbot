{
  "name": "lotto-journal",
  "version": "0.2.4",
  "description": "Lotto Journal as LINE Messaging API and LIFF in a monorepo structure",
  "scripts": {
    "dev": "pnpm db:start && trap 'trap - INT TERM EXIT; pnpm db:stop; exit' INT TERM EXIT; pnpm --filter @lotto/api dev",
    "build": "turbo run build",
    "test:api": "pnpm --filter @lotto/api exec go test -tags=integration ./...",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "pnpm --filter @lotto/api db:start",
    "db:stop": "pnpm --filter @lotto/api db:stop",
    "migrate:up": "pnpm --filter @lotto/api migrate:up",
    "migrate:down": "pnpm --filter @lotto/api migrate:down",
    "migrate:version": "pnpm --filter @lotto/api migrate:version",
    "swagger": "pnpm --filter @lotto/api swagger",
    "mock": "pnpm --filter @lotto/api mock"
  },
  "private": true,
  "author": "Theppitak M.",
  "license": "ISC",
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.9.10"
  }
}