}

get {
  url: {{endpoint_url}}/health
  body: none
  auth: inherit
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });

  test("body.status is ok", function() {
    expect(res.body.status).to.equal("ok");
  });

  test("body.db is ok", function() {
    expect(res.body.db).to.equal("ok");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
